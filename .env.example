# ── LiveKit 配置 ──────────────────────────────
# LiveKit 本地开发服务器（livekit-server --dev 会自动使用这些默认值）
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── 人格配置 ─────────────────────────────────
# 当前仅支持 fengge（峰哥亡命天涯）
PERSONA_NAME=fengge
AGENT_INSTRUCTIONS=你是峰哥（峰哥亡命天涯）的AI分身。说话直白、辩证、有趣。像峰哥直播连线一样聊天。

# ── STT（语音识别）─────────────────────────────
# 推荐 cartesia（ink-whisper，免费层可用）；备选 deepgram / gemini
STT_PROVIDER=cartesia
CARTESIA_API_KEY=your-cartesia-api-key
CARTESIA_STT_MODEL=ink-whisper
CARTESIA_STT_LANGUAGE=zh

# Deepgram 备选（需付费）
# STT_PROVIDER=deepgram
# DEEPGRAM_API_KEY=your-deepgram-api-key
# DEEPGRAM_MODEL=nova-2
# DEEPGRAM_LANGUAGE=zh

# Gemini 备选（需 Google API Key）
# STT_PROVIDER=gemini
# GOOGLE_API_KEY=your-google-api-key
# STT_MODEL=gemini-2.5-flash

# ── LLM（大语言模型）─────────────────────────────
# 推荐 minimax（MiniMax-Text-01，速度最快）
LLM_PROVIDER=minimax
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_MODEL_NAME=MiniMax-Text-01
MINIMAX_MAX_TOKENS=300

# DeepSeek 备选
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-chat

# Gemini 备选
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=your-google-api-key
# LLM_MODEL=gemini-2.5-flash

# ── TTS（语音合成 + 音色克隆）────────────────────
# 方案 A：VoxCPM（开源模型，需 GPU 服务器或本地 GPU）
TTS_PROVIDER=voxcpm
VOXCPM_URL=http://localhost:8000
VOXCPM_VOICE=fengge
VOXCPM_SAMPLE_RATE=24000

# 方案 B：Cartesia Sonic（云端，需 Pro 订阅 $5/月 才能克隆音色）
# TTS_PROVIDER=cartesia
# CARTESIA_API_KEY=your-cartesia-api-key
# CARTESIA_VOICE_ID=your-cloned-voice-id
# CARTESIA_MODEL=sonic-3
# CARTESIA_LANGUAGE=zh
# CARTESIA_SPEED=0.8

# 方案 C：MiniMax TTS（云端）
# TTS_PROVIDER=minimax
# MINIMAX_API_KEY=your-minimax-api-key
# MINIMAX_VOICE_ID=your-voice-id
# MINIMAX_MODEL=speech-02-turbo

# ── OpenViking 记忆系统（可选）────────────────────
OPENVIKING_URL=http://127.0.0.1:1933
# OPENVIKING_DATA_DIR=./data/openviking/viking/default

# ── 调试 ──────────────────────────────────────
DEBUG=false
